{
    "extensions": [".ts", ".js", ".tsx", ".jsx"],
    "ignore": [
        "*.test.ts", "*.spec.ts", "*.test.js", "*.spec.js",
        "node_modules/**", "dist/**", "build/**", "coverage/**",
        "*.d.ts", "*.min.js"
    ],
    "ignore_file": "",
    "accuracy_intensity": 1,
    "output": {
        "format": "md",
        "mode": "vuln_only",
        "scope": "all",
        "per_file": true,
        "mirror_structure": false
    },
    "kb": ["webapp"],
    "ollama_config": {
        "model": "felcon/qwen-pentest:latest",
        "fallback_models": [
            "gemma4:e2b",
            "antconsales/antonio-gemma3-evo-q4-logic:latest"
        ],
        "validation_model": "gemma4:e2b",
        "validation_fallback_models": [],
        "notes": "Web3 TypeScript/JavaScript frontend security audit. Focus: EIP-712 signatures, approval risks, slippage/deadline, off-chain price data, multicall failures, key handling."
    },
    "openrouter_config": {
        "model": "deepseek/deepseek-r1",
        "fallback_models": [
            "anthropic/claude-3.7-sonnet"
        ],
        "validation_model": "anthropic/claude-3.7-sonnet",
        "validation_fallback_models": [],
        "notes": "Web3 TypeScript/JavaScript frontend security audit. Focus: EIP-712 signatures, approval risks, slippage/deadline, off-chain price data, multicall failures, key handling.",
        "OPENROUTER_API_KEY": ""
    }
}
